FROM eclipse-temurin:21-jre AS runtime

WORKDIR /app
COPY compute-controlplane/build/libs/compute-controlplane-*-all.jar /app/app.jar
COPY deploy/definitions /app/definitions

ENV COMPUTE_DEFINITIONS_DIR=/app/definitions \
    HTTP_PORT=8080 \
    TEMPORAL_TARGET=temporal-frontend:7233

EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
